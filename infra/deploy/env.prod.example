# Copy to infra/deploy/.env.prod and fill in values.
# Used by docker-compose.prod.yml and as reference for Railway / Fly / ECS env.

NODE_ENV=production

# HTTP (api container)
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# Managed data (Neon, Upstash, Redpanda Cloud, etc.)
POSTGRES_URL=postgres://user:pass@host/db?sslmode=require
POSTGRES_POOL_SIZE=10
REDIS_URL=rediss://default:pass@host:6379
KAFKA_BROKERS=broker.example.com:9092
KAFKA_CLIENT_ID=smriti
KAFKA_GROUP_ID=smriti-workers

# Managed Kafka (uncomment when not using local plaintext Kafka)
# KAFKA_SSL=true
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# Auth — required in production
API_KEY=

# AI providers
EMBEDDING_PROVIDER=mock
LLM_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Rate limiting (api)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# Worker metrics (0 = disabled)
WORKER_METRICS_PORT=0

# Scheduler
SCHEDULE_SUMMARIZE_MS=300000
SCHEDULE_CONSOLIDATE_MS=900000
SCHEDULE_PROFILE_MS=1800000
SCHEDULE_DECAY_MS=3600000
MEMORY_DECAY_FACTOR=0.95
MEMORY_DECAY_AGE_DAYS=7
MEMORY_ARCHIVE_THRESHOLD=0.05
CONSOLIDATION_SIMILARITY_THRESHOLD=0.92

# Observability (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smriti
