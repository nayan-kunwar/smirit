{
  "name": "@smriti/summarizer-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/main.js --packages=external --tsconfig=tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@smriti/config": "workspace:*",
    "@smriti/events": "workspace:*",
    "@smriti/kafka": "workspace:*",
    "@smriti/llm": "workspace:*",
    "@smriti/memory-core": "workspace:*",
    "@smriti/observability": "workspace:*",
    "@smriti/postgres": "workspace:*",
    "@smriti/shared-types": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "kafkajs": "^2.2.4",
    "kysely": "^0.27.5",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "nx": {
    "tags": [
      "type:app"
    ]
  }
}
